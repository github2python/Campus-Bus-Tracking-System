{
  "name": "campus-bus-tracker-backend",
  "version": "1.0.0",
  "description": "Backend API and Socket.IO server for Campus Bus Tracking",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/scripts/seed.js",
    "test": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles",
    "test:coverage": "cross-env NODE_ENV=test jest --runInBand --coverage --coverageReporters=text-summary",
    "test:watch": "cross-env NODE_ENV=test jest --watch"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "nodemon": "^3.1.4",
    "socket.io-client": "^4.7.5",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": ["/node_modules/"],
    "coveragePathIgnorePatterns": ["/node_modules/", "/scripts/", "/tests/"]
  }
}
